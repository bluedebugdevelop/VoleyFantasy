rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Los jugadores solo los escribe el scraper (Admin SDK, ignora las reglas)
    match /jugadores/{jugadorId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    // Cada usuario solo puede escribir su propio estado
    match /usuarios/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    // Ligas: cualquier usuario autenticado puede crearlas y unirse
    match /ligas/{ligaId} {
      allow read, create, update: if request.auth != null;
      allow delete: if request.auth != null && resource.data.creador == request.auth.uid;
    }
  }
}
